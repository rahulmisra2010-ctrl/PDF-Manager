# =============================================================================
# PDF-Manager — Environment Variables
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="PDF-Manager API"
API_VERSION="1.0.0"
DEBUG=false

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=5000

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Secret key for Flask session signing — generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Password for the auto-created default admin account.
# If left blank a random password is generated and printed at startup.
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# CORS (FastAPI / legacy backend)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ---------------------------------------------------------------------------
# Database
# SQLite (default, no extra setup):
#   DATABASE_URL=sqlite:///instance/pdf_manager.db
# PostgreSQL (legacy):
#   DATABASE_URL=postgresql://pdfmanager:pdfmanager@localhost:5432/pdfmanager
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///instance/pdf_manager.db

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=uploads
EXPORT_DIR=exports
MAX_UPLOAD_SIZE_MB=50

# ---------------------------------------------------------------------------
# ML / PyTorch settings (only relevant when torch is installed)
# ---------------------------------------------------------------------------
ML_MODEL_DIR=models
ML_CONFIDENCE_THRESHOLD=0.75
USE_GPU=false

# ---------------------------------------------------------------------------
# AI/IDP API Keys — Automatic Extraction System
# ---------------------------------------------------------------------------

# Mindee IDP (https://developers.mindee.com)
# Used for structured document extraction (invoices, receipts, IDs)
MINDEE_API_KEY=

# Koncile.ai (https://koncile.ai)
# Enterprise document processing platform
KONCILE_API_KEY=

# OpenAI GPT (https://platform.openai.com)
# LLM-powered semantic field extraction and validation
OPENAI_API_KEY=
# Model to use (default: gpt-3.5-turbo; use gpt-4 for higher accuracy)
OPENAI_MODEL=gpt-3.5-turbo

# ---------------------------------------------------------------------------
# Batch Processing Settings
# ---------------------------------------------------------------------------
# Number of parallel workers for batch file processing
BATCH_MAX_WORKERS=4
# Max retry attempts per file on extraction failure
BATCH_MAX_RETRIES=2
# Maximum seconds to hold an SSE connection open (live progress streaming)
SSE_MAX_WAIT_SECONDS=300
