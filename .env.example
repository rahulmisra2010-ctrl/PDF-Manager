# =============================================================================
# PDF-Manager — Environment Variables
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="PDF-Manager API"
API_VERSION="1.0.0"
DEBUG=false

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=5000

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Secret key for Flask session signing — generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Password for the auto-created default admin account.
# If left blank a random password is generated and printed at startup.
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# CORS (FastAPI / legacy backend)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ---------------------------------------------------------------------------
# Database
# SQLite (default, no extra setup):
#   DATABASE_URL=sqlite:///instance/pdf_manager.db
# PostgreSQL (legacy):
#   DATABASE_URL=postgresql://pdfmanager:pdfmanager@localhost:5432/pdfmanager
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///instance/pdf_manager.db

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=uploads
EXPORT_DIR=exports
MAX_UPLOAD_SIZE_MB=50

# ---------------------------------------------------------------------------
# ML / PyTorch settings (only relevant when torch is installed)
# ---------------------------------------------------------------------------
ML_MODEL_DIR=models
ML_CONFIDENCE_THRESHOLD=0.75
USE_GPU=false

# ---------------------------------------------------------------------------
# IDP / AI Extraction API Keys
# ---------------------------------------------------------------------------
# Mindee IDP — https://developers.mindee.com
MINDEE_API_KEY=

# Koncile.ai — https://koncile.ai
KONCILE_API_KEY=
KONCILE_BASE_URL=https://api.koncile.ai

# OpenAI / LLM extraction — https://platform.openai.com
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Batch Extraction Settings
# ---------------------------------------------------------------------------
# Number of parallel worker threads for batch processing (default: 4)
BATCH_MAX_WORKERS=4
# Number of retry attempts on extraction failure (default: 2)
BATCH_MAX_RETRIES=2
# Minimum quality score to include a sample in the database (0.0–1.0)
SAMPLE_MIN_QUALITY=0.1
