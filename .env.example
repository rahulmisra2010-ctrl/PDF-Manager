# PDF-Manager – environment variable template
# Copy this file to backend/.env and adjust values as needed.
#
#   cp .env.example backend/.env

DEBUG=true
HOST=0.0.0.0
PORT=8000

# Comma-separated JSON array of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# PostgreSQL connection string
DATABASE_URL=postgresql://pdfmanager:pdfmanager@localhost:5432/pdfmanager

# File storage directories (relative to the backend/ working directory)
UPLOAD_DIR=uploads
EXPORT_DIR=exports
MAX_UPLOAD_SIZE_MB=50

# ML settings
ML_MODEL_DIR=models
ML_CONFIDENCE_THRESHOLD=0.75
USE_GPU=false
