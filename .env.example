# PDF-Manager – environment configuration
# =========================================
# Copy this file to backend/.env and adjust the values for your environment.
#
#   cp .env.example backend/.env
#
# All variables listed here correspond to settings in backend/config.py.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Enable debug mode and auto-reload (set to false in production)
DEBUG=false

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# JSON array of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql://pdfmanager:pdfmanager@localhost:5432/pdfmanager

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------

# Directory where uploaded PDFs are saved (relative to backend/ or absolute)
UPLOAD_DIR=uploads

# Directory where exported files are written
EXPORT_DIR=exports

# Maximum upload size in megabytes
MAX_UPLOAD_SIZE_MB=50

# ---------------------------------------------------------------------------
# ML / PyTorch
# ---------------------------------------------------------------------------

# Directory containing pre-trained model weights
ML_MODEL_DIR=models

# Minimum confidence threshold for ML-extracted fields (0.0 – 1.0)
ML_CONFIDENCE_THRESHOLD=0.75

# Set to true to use a CUDA-capable GPU (requires a compatible torch build)
USE_GPU=false
