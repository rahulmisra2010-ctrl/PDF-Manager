# =============================================================================
# PDF-Manager .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# Python test / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Node.js / React ---
node_modules/
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment files ---
.env
.env.*
!.env.example
!.env.production      # production template (no real secrets — placeholders only)
!.env.secrets.template  # secrets management guide (no real secrets)

# --- IDE / OS ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Project runtime artifacts ---
uploads/
exports/
models/
*.log
*.db
instance/
rag_data/

# --- Docker ---
*.override.yml
