# =============================================================================
# PDF-Manager — Production Environment Template
# Copy to .env and fill in all <CHANGE_ME> placeholders before deployment.
# NEVER commit a populated .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="PDF-Manager"
API_VERSION="1.0.0"
DEBUG=false
FLASK_ENV=production

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=5000

# Domain name used by Nginx and Let's Encrypt
DOMAIN_NAME=example.com

# ---------------------------------------------------------------------------
# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
SECRET_KEY=<CHANGE_ME>
WTF_CSRF_ENABLED=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ---------------------------------------------------------------------------
# Admin account (created on first start if users table is empty)
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=<CHANGE_ME>

# ---------------------------------------------------------------------------
# Database — PostgreSQL (managed by PgBouncer in production)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://pdfmanager:${POSTGRES_PASSWORD}@pgbouncer:5432/pdfmanager
POSTGRES_USER=pdfmanager
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=pdfmanager

# ---------------------------------------------------------------------------
# Redis — session store, cache, rate-limit backend
# ---------------------------------------------------------------------------
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=<CHANGE_ME>

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
EXPORT_DIR=/app/exports
LOG_DIR=/app/logs
MAX_UPLOAD_SIZE_MB=100

# ---------------------------------------------------------------------------
# Gunicorn (production WSGI server)
# ---------------------------------------------------------------------------
GUNICORN_WORKERS=5            # typically: (CPU_COUNT * 2) + 1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ---------------------------------------------------------------------------
# CORS — adjust to your frontend origin(s)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["https://example.com"]

# ---------------------------------------------------------------------------
# ML / AI (optional — leave blank to disable)
# ---------------------------------------------------------------------------
ML_MODEL_DIR=/app/models
ML_CONFIDENCE_THRESHOLD=0.75
USE_GPU=false

# ---------------------------------------------------------------------------
# Email / SMTP (for alerts and password-reset flows)
# ---------------------------------------------------------------------------
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=<CHANGE_ME>
MAIL_PASSWORD=<CHANGE_ME>
MAIL_DEFAULT_SENDER=noreply@example.com

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
FEATURE_OCR=true
FEATURE_AI_EXTRACTION=true
FEATURE_RAG=false
