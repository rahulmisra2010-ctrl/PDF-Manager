# =============================================================================
# PDF-Manager — Secrets Management Template
# This file documents which secrets are required and where they are stored.
# Use one of the backends below; do NOT hard-code secrets in source files.
# =============================================================================

# ---------------------------------------------------------------------------
# Option A: AWS Secrets Manager
# ---------------------------------------------------------------------------
# Store each secret as a JSON key-value pair under the path shown.
#
# Secret name: pdfmanager/production
# {
#   "SECRET_KEY":        "<flask-secret-key>",
#   "ADMIN_PASSWORD":    "<initial-admin-password>",
#   "POSTGRES_PASSWORD": "<postgres-password>",
#   "REDIS_PASSWORD":    "<redis-password>",
#   "MAIL_PASSWORD":     "<smtp-password>"
# }
#
# Retrieve at runtime:
#   aws secretsmanager get-secret-value \
#       --secret-id pdfmanager/production \
#       --query SecretString --output text | jq -r '.SECRET_KEY'

# ---------------------------------------------------------------------------
# Option B: HashiCorp Vault (KV v2)
# ---------------------------------------------------------------------------
# vault kv put secret/pdfmanager/production \
#     SECRET_KEY="..." \
#     ADMIN_PASSWORD="..." \
#     POSTGRES_PASSWORD="..." \
#     REDIS_PASSWORD="..." \
#     MAIL_PASSWORD="..."
#
# Retrieve at runtime:
#   vault kv get -field=SECRET_KEY secret/pdfmanager/production

# ---------------------------------------------------------------------------
# Option C: Docker Swarm secrets
# ---------------------------------------------------------------------------
# echo "<value>" | docker secret create pdfmanager_secret_key -
# echo "<value>" | docker secret create pdfmanager_postgres_password -
# echo "<value>" | docker secret create pdfmanager_redis_password -
# (mount as /run/secrets/<name> in the container)

# ---------------------------------------------------------------------------
# Secrets inventory
# ---------------------------------------------------------------------------
# SECRET_KEY             — Flask session signing key (64-char hex)
# ADMIN_PASSWORD         — Default admin account password
# POSTGRES_PASSWORD      — PostgreSQL / PgBouncer password for 'pdfmanager'
# REDIS_PASSWORD         — Redis AUTH password
# MAIL_PASSWORD          — SMTP authentication password
# SSL_CERTIFICATE_KEY    — Private key for TLS certificate (managed by certbot)

# ---------------------------------------------------------------------------
# Rotation policy
# ---------------------------------------------------------------------------
# SECRET_KEY        — rotate every 90 days or after suspected compromise
# ADMIN_PASSWORD    — enforce change on first login; rotate every 90 days
# POSTGRES_PASSWORD — rotate every 180 days; update pgbouncer userlist.txt
# REDIS_PASSWORD    — rotate every 180 days; update redis.conf and app .env
# MAIL_PASSWORD     — rotate per SMTP provider policy
